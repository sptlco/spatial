<!doctype html>
<html>
  <head>
    ${templates.meta} 
    ${templates.styles}
  </head>
  <body style="background: #0a0a0a">
    ${templates.preview}
    <table border="0" cellpadding="0" cellspacing="0" width="100%" style="background: #0a0a0a; color: #ffffff">
      <tr>
        <td align="center" style="padding: 40px 20px">
          ${templates.header}
          <table border="0" cellpadding="0" cellspacing="0" width="100%;" style="color: #ffffff">
            <tr>
              <td align="center" style="padding: 0 0 40px 0;">
                <h1 style="margin: 0 0 12px 0; font-size: 28px; font-weight: 700; line-height: 1.3;">
                  Your key is ready
                </h1>
                <p style="margin: 0; max-width: 384px; font-size: 16px; line-height: 1.1; color: rgba(255,255,255,0.5);">
                  Use the code below to complete your access request. This code is private — do not share it with anyone.
                </p>
              </td>
            </tr>
            <tr>
              <td align="center" style="padding: 0 0 40px 0;">
                <table border="0" cellpadding="0" cellspacing="0">
                  <tr>
                    <td align="center">
                      <p style="margin: 0; font-size: 48px; font-weight: 800; letter-spacing: 0.15em; color: #ffffff;">
                        ${parameters.code}
                      </p>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
            <tr>
              <td align="center" style="padding: 0 0 40px 0;">
                <p style="margin: 0; max-width: 384px; font-size: 12px; line-height: 1.5; color: rgba(255,255,255,0.3);">
                  If you didn't request this code, you can safely disregard this email.
                  Someone may have entered your email address by mistake.
                </p>
              </td>
            </tr>
          </table>
          ${templates.footer}
        </td>
      </tr>
    </table>
  </body>
</html>
