{
  "include-v-in-tag": false,
  "group-pull-request-title-pattern": "Release ${version}",
  "pull-request-header": "Release Notes",
  "pull-request-footer": "This pull request was automatically generated due to code changes.\nPlease review and merge to publish the release.",
  "packages": {
    ".": {
      "package-name": "spatial",
      "changelog-path": "CHANGES.md",
      "release-type": "simple"
    },
    "packages/cloud": {
      "package-name": "spatial-cloud",
      "changelog-path": "CHANGES.md",
      "release-type": "simple",
      "extra-files": [
        "Core/Spatial.csproj",
        {
          "type": "json",
          "path": "Server/appsettings.json",
          "jsonpath": "$.Version"
        }
      ]
    },
    "packages/web": {
      "package-name": "spatial-web",
      "changelog-path": "CHANGES.md",
      "release-type": "simple",
      "extra-files": ["package.json"]
    }
  }
}
